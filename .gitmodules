[submodule "svd"]
	path = svd
	url = https://github.com/modm-io/cmsis-svd-stm32
[submodule "Drivers/cmsis-core"]
	path = Drivers/cmsis-core
	url = https://github.com/STMicroelectronics/cmsis-core
[submodule "Drivers/hal-driver"]
	path = Drivers/hal-driver
	url = https://github.com/STMicroelectronics/stm32f4xx-hal-driver.git
[submodule "Drivers/cmsis-device"]
	path = Drivers/cmsis-device
	url = https://github.com/STMicroelectronics/cmsis-device-f4.git
